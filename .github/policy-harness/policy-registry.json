      ],
      "ownedAreas": [
        "src/adapters/vue/stores/**",
        "src/adapters/vue/composables/**"
      ],
      "checks": [
        "store-placement",
        "composable-placement",
        "adapter-ui-boundary"
      ]
    },
    {
      "id": "feature-sliced-design",
      "title": "Feature boundaries and shared purity",
      "documents": [
