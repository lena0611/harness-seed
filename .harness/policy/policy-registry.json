{
  "version": 2,
  "policies": [
    {
      "id": "policy-harness",
      "title": "Policy synchronization harness",
      "documents": [
        ".harness/policy/**",
        ".harness/session/**"
      ],
      "ownedAreas": [
        ".harness/policy/**",
        ".harness/session/**",
        "scripts/policy-harness.mjs",
        "scripts/doc-link-check.mjs",
        "scripts/apply-stack.mjs",
        "scripts/guard.mjs",
        ".github/workflows/policy-guard.yml"
      ],
      "checks": []
    },
    {
      "id": "documentation-harness",
      "title": "Documentation registry and link integrity",
      "documents": [
        ".harness/documentation/**"
      ],
      "ownedAreas": [
        ".harness/documentation/**",
        "scripts/doc-link-check.mjs"
      ],
      "checks": []
    },
    {
      "id": "stack-preset",
      "title": "Stack preset bundle integrity",
      "documents": [
        ".harness/stacks/**"
      ],
      "ownedAreas": [
        ".harness/stacks/**",
        ".harness/policy/profile.json",
        "scripts/apply-stack.mjs"
      ],
      "checks": []
    }
  ]
}
