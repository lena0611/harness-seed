    {
      "id": "common.policy.registry-schema",
      "title": "Policy registry must remain machine-readable",
      "layer": "common",
      "category": "policy-db-readiness",
      "status": "active",
      "severity": "error",
      "enforcement": "hook",
      "waiverAllowed": false,
      "owner": "ai-standard/harness-seed",
