{
  "version": 3,
  "schema": {
    "required": [
      "id",
      "title",
      "layer",
      "category",
      "status",
      "severity",
      "enforcement",
      "waiverAllowed",
      "owner",
      "source",
      "documents",
      "ownedAreas",
      "checks"
