{
  "version": 2,
  "policies": [
    {
      "id": "policy-harness",
      "title": "Policy synchronization harness",
      "documents": [
        ".harness/policy/**",
        ".harness/session/**"
      ],
      "ownedAreas": [
        ".harness/policy/**",
        ".harness/session/**",
        ".harness/bin/policy-harness.mjs",
        ".harness/bin/sync-context.mjs",
        ".harness/bin/build-context.mjs",
        ".harness/bin/doc-link-check.mjs",
        "scripts/test-init.mjs",
        "scripts/init.mjs",
        ".harness/bin/scan-project.mjs",
        ".harness/bin/handoff.mjs",
        ".harness/bin/apply-stack.mjs",
        ".harness/bin/outdated-harness.mjs",
        ".harness/bin/update-harness.mjs",
        ".harness/bin/guard.mjs"
      ],
      "checks": []
    },
    {
      "id": "documentation-harness",
      "title": "Documentation registry and link integrity",
      "documents": [
        ".harness/documentation/**"
      ],
      "ownedAreas": [
        ".harness/documentation/**",
        ".harness/bin/doc-link-check.mjs"
      ],
      "checks": []
    },
    {
      "id": "stack-preset",
      "title": "Stack preset bundle integrity",
      "documents": [
        ".harness/stacks/**"
      ],
      "ownedAreas": [
        ".harness/stacks/**",
        ".harness/policy/profile.json",
        ".harness/bin/apply-stack.mjs",
        ".harness/bin/outdated-harness.mjs",
        ".harness/bin/update-harness.mjs",
        ".harness/bin/list-stack-standards.mjs"
      ],
      "checks": []
    }
  ]
}
