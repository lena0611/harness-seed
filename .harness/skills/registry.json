      "purpose": "운영 업무 완료 후보에 대해 사용자 승인을 받은 뒤 JIRA, 요청 개요, 핵심 변경, 검증, 잠재 이슈를 연도별 유지보수 히스토리로 남기고 결정로그 또는 프로젝트 룰 승격 여부를 판단한다.",
      "audience": ["consumer"],
      "taskTypes": ["bugfix", "feature", "refactor", "maintenance", "verification"],
      "priority": "high",
      "triggers": ["업무요약", "업무 요약", "유지보수 히스토리", "작업 요약", "JIRA"],
      "read": [
        ".harness/maintenance/README.md",
        ".harness/session/active-context.md",
        ".harness/session/decision-log.md",
        ".harness/session/project-memory.md"
      ],
      "commands": [
        "npm run harness:impact",
        "npm run harness:check"
      ],
      "outputs": [
        "요청 JIRA URL",
        "요청 개요",
        "핵심 개발 내용",
        "검증 결과",
        "사용자 완료 승인 여부",
        "잠재 이슈 또는 TODO",
        "decision-log 기록 필요 여부",
        "project rule 승격 필요 여부"
      ],
      "records": [
        ".harness/maintenance/work-history/YYYY/",
        ".harness/session/next-session-reminder.md",
        ".harness/session/decision-log.md",
        ".harness/session/project-memory.md",
        ".harness/project/domain-rules.md",
        ".harness/project/architecture-rules.md",
        ".harness/project/workflow-rules.md"
      ]
    },
    {
      "id": "harness.ui-change-guard",
      "title": "UI 변경 가드 흐름",
      "purpose": "UI 변경 요청에서 공통 컴포넌트 재사용, 디자인 토큰, 테마, 모바일 레이아웃 제약을 먼저 확인한다.",
      "audience": ["consumer"],
      "taskTypes": ["ui", "feature", "bugfix", "refactor"],
      "priority": "high",
      "triggers": ["UI", "화면", "디자인", "컴포넌트", "레이아웃", "safe area", "테마", "모바일"],
      "read": [
        ".harness/project/architecture-rules.md",
        ".harness/project/workflow-rules.md",
        ".harness/project/critical-paths.md",
        ".harness/project/stack-preset-rules.md"
      ],
      "commands": [
        "npm run harness:context -- \"<UI 작업 설명>\"",
        "npm run harness:impact",
        "npm run harness:check"
      ],
      "outputs": [
        "기존 공통 컴포넌트 재사용 가능 여부",
        "새 컴포넌트의 공통 승격 필요 여부",
        "디자인 토큰/테마/모바일 레이아웃/키보드/WebView 고려 여부",
        "UI 회귀 검증 필요 여부"
      ],
      "records": [
        ".harness/project/architecture-rules.md",
        ".harness/project/workflow-rules.md",
        ".harness/session/decision-log.md"
      ]
    },
    {
      "id": "harness.test-selection-guard",
      "title": "테스트 선택 가드 흐름",
      "purpose": "기능 개발이나 버그 수정 후 단위, 통합, E2E, 수동 검증 중 어떤 검증이 필요한지 판단한다.",
      "audience": ["consumer"],
      "taskTypes": ["feature", "bugfix", "refactor", "verification", "supabase", "native", "domain-logic"],
      "priority": "high",
      "triggers": ["테스트", "검증", "회귀", "라우트", "추론", "Edge Function", "외부 연동", "E2E"],
      "read": [
        ".harness/project/workflow-rules.md",
        ".harness/project/critical-paths.md",
        ".harness/session/manual-actions.md",
        ".harness/session/decision-log.md"
      ],
      "commands": [
        "npm run harness:impact",
