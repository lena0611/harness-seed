{
  "_comment": "apply-stack 적용 시 root package.json에 머지되는 키. 'scripts'는 충돌 시 root 우선(즉, harness 스크립트 보호).",
  "scripts": {
    "dev": "bash scripts/dev.sh",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "pinia": "^3.0.2",
    "vue": "^3.5.22"
  },
  "devDependencies": {
    "@eslint/js": "^9.38.0",
    "@vue/tsconfig": "^0.8.1",
    "@vitejs/plugin-vue": "^6.0.1",
    "eslint": "^9.38.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-vue": "^10.5.1",
    "globals": "^16.4.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.2",
    "vite": "^7.1.9",
    "vitest": "^3.2.4",
    "vue-tsc": "^3.1.1"
  }
}
