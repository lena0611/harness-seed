{
  "version": 1,
  "stackId": "vue3-fsd",
  "policies": [
    {
      "id": "architecture-core",
      "title": "Core isolation and dependency direction",
      "documents": [
        ".harness/stacks/vue3-fsd/instructions/architecture.md",
        ".github/copilot-instructions/development-workflow.md"
      ],
      "ownedAreas": [
        "src/core/**",
        "src/adapters/**",
        "src/pages/**",
        "src/widgets/**",
        "src/features/**"
      ],
      "checks": [
        "core-purity",
        "adapter-ui-boundary"
      ]
    },
    {
      "id": "state-management",
      "title": "Pinia and composable adapter rules",
      "documents": [
        ".harness/stacks/vue3-fsd/instructions/state-management.md"
      ],
      "ownedAreas": [
        "src/adapters/vue/stores/**",
        "src/adapters/vue/composables/**"
      ],
      "checks": [
        "store-placement",
        "composable-placement",
        "adapter-ui-boundary"
      ]
    },
    {
      "id": "feature-sliced-design",
      "title": "Feature boundaries and shared purity",
      "documents": [
        ".harness/stacks/vue3-fsd/instructions/feature-sliced-design.md",
        ".harness/stacks/vue3-fsd/instructions/architecture.md"
      ],
      "ownedAreas": [
        "src/features/**",
        "src/shared/**",
        "src/entities/**"
      ],
      "checks": [
        "feature-structure",
        "shared-boundary",
        "no-dumping-folders"
      ]
    }
  ]
}
