{
  "name": "harness-seed",
  "version": "0.2.68",
  "type": "module",
  "engines": {
    "node": ">=20.19.0"
  },
  "bin": {
    "harness-seed": "./scripts/init.mjs"
  },
  "files": [
    ".harness",
    "!.harness/generated",
    "!.harness/generated/**",
    "!.harness/stacks/.applied",
    "!.harness/stacks/.applied/**",
    "!.harness/templates/.applied",
    "!.harness/templates/.applied/**",
    "!.harness/session/project-scan-report.md",
    "!.harness/session/handoff.md",
    "!.harness/session/task-context.md",
    "!.harness/install-manifest.json",
    "!.harness/harness-lock.json",
    "!.harness/.stack-applied.json",
    "!.harness/.template-applied.json",
    ".claude",
    ".codex",
    ".github/commit-template.txt",
    ".github/copilot-instructions.md",
    ".github/copilot-instructions",
    "scripts",
    ".githooks",
    "AGENTS.md",
    "CLAUDE.md",
    "CHANGELOG.md",
    "README.md"
  ],
  "scripts": {
    "node:check": "node .harness/bin/check-node-version.mjs",
    "harness:scan": "npm run node:check --silent && node .harness/bin/scan-project.mjs --write",
    "harness:handoff": "npm run node:check --silent && node .harness/bin/handoff.mjs --write",
    "harness:check": "npm run node:check --silent && node .harness/bin/guard.mjs",
    "harness:check:strict": "npm run node:check --silent && node .harness/bin/guard.mjs --strict",
    "harness:guide": "npm run node:check --silent && node .harness/bin/harness-guide.mjs",
    "harness:impact": "npm run node:check --silent && node .harness/bin/policy-harness.mjs impact",
    "harness:sync": "npm run node:check --silent && node .harness/bin/sync-context.mjs",
    "harness:context": "npm run node:check --silent && node .harness/bin/build-context.mjs",
    "hooks:install": "npm run node:check --silent && node .harness/bin/install-hooks.mjs",
    "policy:check": "npm run node:check --silent && node .harness/bin/policy-harness.mjs check",
    "policy:impact": "npm run node:check --silent && node .harness/bin/policy-harness.mjs impact",
    "policy:guard": "npm run node:check --silent && node .harness/bin/policy-harness.mjs guard",
    "policy:guard:strict": "npm run node:check --silent && node .harness/bin/policy-harness.mjs guard --strict",
    "docs:check": "npm run node:check --silent && node .harness/bin/doc-link-check.mjs",
    "docs:check:strict": "npm run node:check --silent && node .harness/bin/doc-link-check.mjs --strict",
    "harness:outdated": "npm run node:check --silent && node .harness/bin/outdated-harness.mjs",
    "harness:update": "npm run node:check --silent && node .harness/bin/update-harness.mjs",
    "harness:changelog": "npm run node:check --silent && node .harness/bin/changelog-delta.mjs",
    "standards:list": "npm run node:check --silent && node .harness/bin/list-stack-standards.mjs",
    "templates:list": "npm run node:check --silent && node .harness/bin/list-templates.mjs",
    "stack:apply": "npm run node:check --silent && node .harness/bin/apply-stack.mjs",
    "stack:reset": "npm run node:check --silent && node .harness/bin/apply-stack.mjs --reset",
    "stack:status": "npm run node:check --silent && node .harness/bin/apply-stack.mjs --status",
    "template:apply": "npm run node:check --silent && node .harness/bin/apply-stack.mjs --template",
    "template:reset": "npm run node:check --silent && node .harness/bin/apply-stack.mjs --template-reset",
    "template:status": "npm run node:check --silent && node .harness/bin/apply-stack.mjs --template-status"
  }
}
