{
  "name": "bareunmal",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "bin": {
    "bareunmal": "./scripts/init.mjs"
  },
  "files": [
    ".github",
    "scripts",
    ".githooks",
    "README.md"
  ],
  "scripts": {
    "guard": "node scripts/guard.mjs",
    "hooks:install": "node scripts/install-hooks.mjs",
    "policy:check": "node scripts/policy-harness.mjs check",
    "policy:impact": "node scripts/policy-harness.mjs impact",
    "policy:guard": "node scripts/policy-harness.mjs guard",
    "policy:guard:strict": "node scripts/policy-harness.mjs guard --strict",
    "docs:check": "node scripts/doc-link-check.mjs",
    "docs:check:strict": "node scripts/doc-link-check.mjs --strict",
    "stack:apply": "node scripts/apply-stack.mjs",
    "stack:reset": "node scripts/apply-stack.mjs --reset",
    "stack:status": "node scripts/apply-stack.mjs --status"
  }
}
