{
  "name": "harness-seed",
  "version": "0.2.16",
  "type": "module",
  "engines": {
    "node": ">=20.19.0"
  },
  "bin": {
    "harness-seed": "./scripts/init.mjs"
  },
  "files": [
    ".harness",
    ".claude",
    ".github",
    "scripts",
    ".githooks",
    "AGENTS.md",
    "CLAUDE.md",
    "README.md"
  ],
  "scripts": {
    "node:check": "node scripts/check-node-version.mjs",
    "harness:doctor": "npm run node:check --silent && node scripts/absorb-project.mjs --write",
    "harness:check": "npm run node:check --silent && node scripts/guard.mjs",
    "harness:check:strict": "npm run node:check --silent && node scripts/guard.mjs --strict",
    "guard": "npm run node:check --silent && node scripts/guard.mjs",
    "hooks:install": "npm run node:check --silent && node scripts/install-hooks.mjs",
    "policy:check": "npm run node:check --silent && node scripts/policy-harness.mjs check",
    "policy:impact": "npm run node:check --silent && node scripts/policy-harness.mjs impact",
    "policy:guard": "npm run node:check --silent && node scripts/policy-harness.mjs guard",
    "policy:guard:strict": "npm run node:check --silent && node scripts/policy-harness.mjs guard --strict",
    "docs:check": "npm run node:check --silent && node scripts/doc-link-check.mjs",
    "docs:check:strict": "npm run node:check --silent && node scripts/doc-link-check.mjs --strict",
    "absorb:report": "npm run harness:doctor",
    "harness:outdated": "npm run node:check --silent && node scripts/outdated-harness.mjs",
    "harness:update": "npm run node:check --silent && node scripts/update-harness.mjs",
    "standards:list": "npm run node:check --silent && node scripts/list-stack-standards.mjs",
    "stack:list": "npm run standards:list",
    "templates:list": "npm run node:check --silent && node scripts/list-templates.mjs",
    "stack:apply": "npm run node:check --silent && node scripts/apply-stack.mjs",
    "stack:reset": "npm run node:check --silent && node scripts/apply-stack.mjs --reset",
    "stack:status": "npm run node:check --silent && node scripts/apply-stack.mjs --status",
    "template:apply": "npm run node:check --silent && node scripts/apply-stack.mjs --template",
    "template:reset": "npm run node:check --silent && node scripts/apply-stack.mjs --template-reset",
    "template:status": "npm run node:check --silent && node scripts/apply-stack.mjs --template-status"
  }
}
