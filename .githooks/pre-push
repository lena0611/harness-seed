#!/usr/bin/env sh
set -eu

if [ -z "${NVM_DIR:-}" ]; then
  export NVM_DIR="$HOME/.nvm"
fi

if [ -s "$NVM_DIR/nvm.sh" ]; then
  # git hook은 로그인 셸의 nvm 상태를 물려받지 않을 수 있으므로 프로젝트 Node를 직접 적용한다.
  # nvm.sh와 nvm use는 set -u와 호환되지 않는다. dash(sh=dash인 Linux)에서는 미설정 변수
  # 참조가 expansion error라 `|| true`로도 잡히지 않고 hook 전체가 exit 2로 죽으므로 잠시 끈다.
  set +u
  . "$NVM_DIR/nvm.sh"
  nvm use >/dev/null 2>&1 || true
  set -u
fi

# 기존 프로젝트 pre-push hook이 있으면 먼저 실행
node .harness/bin/run-previous-hook.mjs pre-push "$@"

# P3(2026-06-09): npm/package.json 없는 비-Node 프로젝트에서도 동작하도록 npm 대신 harness 런처를 호출한다.
.harness/bin/harness check --fast

# 시드 모드 전용 원격 동기화 가드(비차단): GitHub/GitLab 같은 다중 원격이 어긋나지 않게 알림.
# .harness-seed-mode가 없는 소비자 프로젝트에서는 no-op. push를 막지 않는다.
node .harness/bin/check-remote-sync.mjs "$@" || true
